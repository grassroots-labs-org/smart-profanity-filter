{
  "name": "bekindprofanityfilter",
  "version": "0.0.9",
  "description": "A multi-language profanity filter with romanization detection, language-aware innocence scoring, leet-speak detection, and cross-language collision handling. Forked from AllProfanity.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm.min.js",
  "types": "dist/esm/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm.min.js"
      },
      "require": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc && esbuild dist/esm/index.js --bundle --minify --platform=node --format=esm --outfile=dist/esm.min.js --packages=bundle && esbuild dist/esm/index.js --bundle --minify --platform=node --format=cjs --outfile=dist/cjs/index.js --packages=bundle && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "benchmark": "bun run build && node --expose-gc dist/benchmark/profanity-benchmark.js",
    "benchmark:no-gc": "bun run build && node dist/benchmark/profanity-benchmark.js",
    "benchmark:competitors": "bun run benchmark/competitor-benchmark.ts",
    "benchmark:accuracy": "bun run benchmark/accuracy-benchmark.ts",
    "clean": "rimraf dist coverage",
    "prepare": "bun run clean && bun run build",
    "publish": "bun test && bun run build"
  },
  "keywords": [
    "profanity",
    "filter",
    "bad-words",
    "censorship",
    "content-moderation",
    "aho-corasick",
    "bloom-filter",
    "pattern-matching",
    "hindi",
    "hinglish",
    "multi-language",
    "romanization",
    "language-aware",
    "cross-language",
    "typescript",
    "performance",
    "fast",
    "leet-speak"
  ],
  "author": {
    "name": "Ayush Jadaun",
    "email": "ayushjadaun6@gmail.com",
    "url": "https://github.com/ayush-jadaun"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grassroots-labs-org/be-kind-profanity-filter.git"
  },
  "homepage": "https://github.com/grassroots-labs-org/be-kind-profanity-filter#readme",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "bad-words": "^4.0.0",
    "esbuild": "^0.27.4",
    "glin-profanity": "^3.3.0",
    "jest": "^29.5.0",
    "leo-profanity": "^1.9.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.0.0",
    "typescript": "^4.0.0"
  },
  "files": [
    "dist/esm.min.js",
    "dist/esm/**/*.d.ts",
    "!dist/esm/languages/*-words.d.ts",
    "dist/cjs/index.js",
    "dist/cjs/package.json",
    "bin",
    "LICENSE",
    "README.md",
    "allprofanity.config.example.json",
    "config.schema.json",
    "CONTRIBUTORS.md"
  ],
  "bin": {
    "bekindprofanityfilter": "./bin/init.js"
  },
  "dependencies": {
    "eld": "^2.0.2"
  }
}
